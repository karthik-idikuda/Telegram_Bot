# ==================================
# 🔐 ENVIRONMENT VARIABLES TEMPLATE
# ==================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to Git!

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get from @BotFather on Telegram

# ===== OPENROUTER API (for GPT) =====
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Get from https://openrouter.ai/keys

# ===== GOOGLE SHEETS (Optional) =====
SHEET_ID=your_google_sheet_id_here
# The ID from your Google Sheet URL

# ===== GMAIL (Optional - for email tasks) =====
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
# Get app password from Google Account settings

# ===== OPENAI (Optional - for voice transcription) =====
OPENAI_API_KEY=your_openai_api_key_here
# Only needed if using voice messages

# ===== BOT PERSONALITY (Optional) =====
# Options: coach, friendly, professional
BOT_PERSONALITY=coach
